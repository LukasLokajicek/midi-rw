{
  "name": "midi-rw",
  "version": "v0.0.0",
  "description": "Lightweight MIDI file read/write library for browser and Node.js",
  "author": "Lukas Lokajicek <lukas.lokajicek@gmail.com>",
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "test": "jest --no-coverage",
    "testCoverage": "jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "midi",
    "music",
    "smf",
    "standard-midi-file",
    "parser",
    "generator"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LukasLokajicek/midi-rw.git"
  },
  "bugs": {
    "url": "https://github.com/LukasLokajicek/midi-rw/issues"
  },
  "homepage": "https://github.com/LukasLokajicek/midi-rw#readme",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  }
}